# Copy this file to .env and fill in real values. .env itself should never be committed.

# Path to the yt-dlp binary. Leave blank to auto-detect via `which yt-dlp`.
# macOS (Homebrew, Apple Silicon): /opt/homebrew/bin/yt-dlp
# macOS (Homebrew, Intel):         /usr/local/bin/yt-dlp
# Render (installed via pip in render-build.sh, on PATH):  yt-dlp
YTDLP_PATH=

# Optional: path to a cookies.txt file (Netscape format) exported from your
# own logged-in YouTube session. Cloud/datacenter IPs (Render, AWS, etc.) are
# frequently hit with YouTube's "Sign in to confirm you're not a bot" check,
# and this is yt-dlp's standard documented workaround for that.
# Export one with a browser extension like "Get cookies.txt LOCALLY", then
# upload the file to your server and point this at it, e.g. ./cookies.txt
YTDLP_COOKIES_PATH=

# Comma-separated list of allowed frontend origins, e.g.
# https://yourapp.netlify.app,http://localhost:5173
# Leave as * only for local development.
ALLOWED_ORIGIN=*

# Max simultaneous downloads before returning 429 to new requests
MAX_CONCURRENT_DOWNLOADS=3

# Kill any single download that runs longer than this (ms)
DOWNLOAD_TIMEOUT_MS=600000

# Delete finished files from the downloads folder after this long (ms)
MAX_FILE_AGE_MS=1800000

# Set automatically by most hosts (Render, Railway) — leave unset locally
PORT=3000
